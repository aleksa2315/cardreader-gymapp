# Backend MySQL configuration
DB_HOST=mysql-cardreader.alwaysdata.net
DB_PORT=3306
DB_NAME=cardreader_membership
DB_USERNAME=cardreader
DB_PASSWORD=your_password_here

# JWT: set a long random secret before deployment
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRATION_MINUTES=720

# Initial admin user, created only when app_users table is empty
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
ADMIN_FULL_NAME=Administrator

# Frontend URL for CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200
